# Metrotherapy environment contract
# Copy this file to .env only for local/dev use.
# In production prefer systemd EnvironmentFile or real environment variables.

# --- App mode ---
APP_ENV=dev
LOAD_DOTENV=1
PYTHONDONTWRITEBYTECODE=1

# --- Telegram ---
BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_TRANSPORT=polling
TELEGRAM_WEBHOOK_ENABLED=0
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8081
TELEGRAM_WEBHOOK_PREFIX=/telegram-webhook
TELEGRAM_WEBHOOK_PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0

# --- Healthcheck ---
HEALTHCHECK_ENABLED=1
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=8082

# --- Admins ---
# Use comma-separated Telegram user ids, for example: 123456,987654
ADMIN_IDS=

# --- Telegram Payments / YooKassa through BotFather ---
PAY_PROVIDER_TOKEN=
YOOKASSA_TAX_SYSTEM_CODE=2
YOOKASSA_VAT_CODE=1
YOOKASSA_PAYMENT_SUBJECT=service
YOOKASSA_PAYMENT_MODE=full_payment

# --- YooKassa web checkout / reconciliation endpoint ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
PAYMENT_AMOUNT_RUB=990
GIFT_PAYMENT_AMOUNT_RUB=990
PAYMENT_DESCRIPTION=Метротерапия — доступ к аудиопрактикам
GIFT_PAYMENT_DESCRIPTION=Метротерапия — подарок
PAYMENT_RETURN_URL=https://metrotherapy.ru
YOOKASSA_RECEIPT_EMAIL=support@metrotherapy.ru

# --- Database ---
# sqlite is default. For postgres set METRO_DB_ENGINE=postgres and DATABASE_URL.
METRO_DB_ENGINE=sqlite
METRO_DB_PATH=data/data.db
DATABASE_URL=

# --- Audio/content ---
AUDIO_DIR=audio/full
DEMO_DIR=audio/demo
DEMO_LIMIT=0
TRACK_DURATION_SEC=1680

# --- Scheduler / funnel ---
TIMEZONE=Europe/Moscow
MORNING_TIME=08:30
EVENING_TIME=19:30
DEMO_REMINDER_MINUTES=5
FUNNEL_AFTER_DEMO_MINUTES=30
FUNNEL_POSTDEMO_MINUTES=10
FUNNEL_DEADLINE_HOURS=24
FUNNEL_LASTCALL_HOURS=48
STARTUP_NETWORK_RETRIES=5

# --- Referral / bonuses ---
REF_BONUS_WEEK_DAYS=3
REF_BONUS_MONTH_DAYS=7
REF_MAX_BONUSES=10

# --- Optional MAX/VK messenger ingress ---
MESSENGER_WEBHOOK_ENABLED=0
MESSENGER_WEBHOOK_HOST=0.0.0.0
MESSENGER_WEBHOOK_PORT=8081
MESSENGER_PUBLIC_BASE_URL=
MESSENGER_BRIDGE_TOKEN_TTL_HOURS=72
MAX_BOT_TOKEN=
MAX_BOT_NAME=
MAX_BOT_LINK_BASE=
VK_GROUP_TOKEN=
VK_CONFIRMATION_TOKEN=
VK_SECRET=
VK_GROUP_ID=
VK_API_VERSION=5.199

# --- Optional AI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_ENABLED=0

# --- Validation/release gates ---
VALIDATOR_STRICT=0
VALIDATOR_RELEASE_MODE=0
VALIDATOR_GUARDRAILS_STRICT=0

# --- Optional prewarm/self-heal ---
PREWARM_ENABLED=0
PREWARM_CHAT_ID=
APP_SELF_HEAL_RESTART=0
APP_SELF_HEAL_BACKOFF_SEC=2
SOVEREIGN_ENABLED=0
