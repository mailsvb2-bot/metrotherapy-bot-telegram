TELEGRAM_TRANSPORT=polling
TELEGRAM_WEBHOOK_ENABLED=0
# Backward-compatible flag: if set to 1, runtime will also treat Telegram transport as webhook.
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8081
TELEGRAM_WEBHOOK_PREFIX=/telegram-webhook
TELEGRAM_WEBHOOK_PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0
TELEGRAM_BOT_USERNAME=

# MAX / VK integrations (optional)
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_BOT_NAME=
MAX_BOT_LINK_BASE=https://max.ru/<botName>
VK_GROUP_TOKEN=
VK_CONFIRMATION_TOKEN=
VK_SECRET=
VK_GROUP_ID=
VK_API_VERSION=5.199

# AI / outbound
# Default OpenAI-compatible configuration. AI is used only for admin/marketing scopes.
AI_ENABLED=1
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_THINKING=disabled

# DeepSeek via OpenAI-compatible endpoint.
# Keep AI_PROVIDER=openai because DeepSeek exposes an OpenAI-compatible Chat Completions API.
# By default the provider disables thinking for api.deepseek.com unless OPENAI_THINKING=enabled.
# AI_PROVIDER=openai
# OPENAI_API_KEY=PASTE_DEEPSEEK_KEY
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_THINKING=disabled
# For reasoning mode use deepseek-reasoner and explicitly set OPENAI_THINKING=enabled.

# Scheduling / runtime tuning
MORNING_TIME=08:30
EVENING_TIME=19:30
SOFT_CALLBACK_RATE_LIMIT_SEC=0.05
SOFT_MESSAGE_RATE_LIMIT_SEC=0.05
PREWARM_ENABLED=0
