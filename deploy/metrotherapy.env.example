# Core runtime
APP_ENV=prod
BOT_TOKEN=PASTE_BOT_TOKEN
PAY_PROVIDER_TOKEN=PASTE_PROVIDER_TOKEN
ADMIN_IDS=123456789

# Database engine
# Default remains SQLite. For Postgres set both lines below.
METRO_DB_ENGINE=sqlite
DATABASE_URL=

TIMEZONE=Europe/Amsterdam

# Paths outside project tree
METRO_DB_PATH=/var/lib/metrotherapy/data.db
LOG_PATH=/var/log/metrotherapy/app.log

# Health runtime (local only)
HEALTHCHECK_ENABLED=1
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=8082

# Optional webhook runtime behind nginx
# For MAX production webhook: nginx must expose https://bot.example.com/webhooks/max on port 443
# and proxy it to MESSENGER_WEBHOOK_HOST:MESSENGER_WEBHOOK_PORT.
MESSENGER_WEBHOOK_ENABLED=0
MESSENGER_WEBHOOK_HOST=127.0.0.1
MESSENGER_WEBHOOK_PORT=8081
MESSENGER_PUBLIC_BASE_URL=https://bot.example.com

# Telegram transport
# polling = current safe default
# webhook = receive Telegram updates through nginx -> aiohttp runtime on 8081
TELEGRAM_TRANSPORT=polling
TELEGRAM_WEBHOOK_ENABLED=0
# Backward-compatible flag: if set to 1, runtime will also treat Telegram transport as webhook.
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8081
TELEGRAM_WEBHOOK_PREFIX=/telegram-webhook
TELEGRAM_WEBHOOK_PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0
TELEGRAM_BOT_USERNAME=

# MAX integration (optional)
# MAX outbound API uses Authorization: <MAX_BOT_TOKEN>.
# MAX webhook subscription should point to MESSENGER_PUBLIC_BASE_URL + /webhooks/max
# and use MAX_WEBHOOK_SECRET; inbound requests must contain X-Max-Bot-Api-Secret.
MAX_BOT_TOKEN=
MAX_BOT_NAME=
MAX_BOT_LINK_BASE=https://max.ru/<botName>
MAX_WEBHOOK_SECRET=
MAX_API_BASE_URL=https://platform-api.max.ru

# VK integration (optional)
VK_GROUP_TOKEN=
VK_CONFIRMATION_TOKEN=
VK_SECRET=
VK_GROUP_ID=
VK_API_VERSION=5.199

# AI / outbound
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_ENABLED=1

# Scheduling / runtime tuning
MORNING_TIME=08:30
EVENING_TIME=19:30
SOFT_CALLBACK_RATE_LIMIT_SEC=0.05
SOFT_MESSAGE_RATE_LIMIT_SEC=0.05
PREWARM_ENABLED=0
PREWARM_CHAT_ID=

# Optional payment receipt tuning
YOOKASSA_TAX_SYSTEM_CODE=2
YOOKASSA_VAT_CODE=1
YOOKASSA_PAYMENT_SUBJECT=service
YOOKASSA_PAYMENT_MODE=full_payment
