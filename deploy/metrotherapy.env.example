# Metrotherapy production environment example.
# Fill real secret values only on the server, never in the repository.

APP_ENV=prod
BOT_TOKEN=
ADMIN_IDS=

VALIDATOR_RELEASE_MODE=1
VALIDATOR_GUARDRAILS_STRICT=1

TOKEN_ENFORCEMENT_MODE=hard
TOKEN_ECONOMY_ENABLED=1

# Production storage contract: Postgres only.
METRO_DB_ENGINE=postgres
DATABASE_URL=postgresql://localhost:5432/metrotherapy

TIMEZONE=Europe/Amsterdam
LOG_PATH=/var/log/metrotherapy/app.log

# Optional in-process restart guard. systemd remains the canonical supervisor.
APP_SELF_HEAL_RESTART=0
APP_SELF_HEAL_MAX_RESTARTS=3
APP_SELF_HEAL_BACKOFF_SEC=2

HEALTHCHECK_ENABLED=1
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=8082

# Shared HTTP ingress bind. Individual surfaces are enabled independently below.
MESSENGER_WEBHOOK_ENABLED=0
MESSENGER_WEBHOOK_HOST=127.0.0.1
MESSENGER_WEBHOOK_PORT=8081
MESSENGER_PUBLIC_BASE_URL=https://metrotherapy.ru
PAYMENT_PUBLIC_BASE_URL=https://metrotherapy.ru
PAYMENT_HTTP_ENABLED=1
MAX_WEBHOOK_ENABLED=0
VK_WEBHOOK_ENABLED=0

# Telegram production contract: polling only.
TELEGRAM_TRANSPORT=polling
TELEGRAM_WEBHOOK_ENABLED=0
TELEGRAM_LEGACY_TOKEN_WEBHOOK_ENABLED=0
ALLOW_INSECURE_TELEGRAM_WEBHOOK=0
TELEGRAM_BOT_USERNAME=metrotherapybot

# Telegram Stars are an additional Telegram-only checkout. YooKassa remains enabled.
# Prices are integer Stars (XTR). Defaults in code match the values below, so these
# variables are only needed when business pricing must change without a deployment.
TELEGRAM_STARS_ENABLED=1
TELEGRAM_STARS_PRICE_PRACTICE_START_7=1900
TELEGRAM_STARS_PRICE_PRACTICE_60=7900
TELEGRAM_STARS_PRICE_PRACTICE_ANTISTRESS_60=12900
TELEGRAM_STARS_PRICE_PRACTICE_PERSONAL_MONTH=23000

# Optional Telegram webhook fields are dev/compatibility only and must stay empty in prod.
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8081
TELEGRAM_WEBHOOK_PREFIX=/telegram-webhook
TELEGRAM_WEBHOOK_PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0

# YooKassa production checkout and reconciliation.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PAYMENT_CHECKOUT_SIGNING_KEY=
# Optional defense in depth only when a trusted reverse proxy injects
# X-Metrotherapy-Webhook-Secret. Native YooKassa notifications do not send this
# custom header; grant-producing events are verified against YooKassa's API.
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_RECEIPT_EMAIL=
YOOKASSA_TAX_SYSTEM_CODE=2
YOOKASSA_VAT_CODE=1
YOOKASSA_PAYMENT_SUBJECT=service
YOOKASSA_PAYMENT_MODE=full_payment

# Bearer audio links expire; accepted range is 1..168 hours.
AUDIO_ACCESS_TOKEN_TTL_HOURS=24

# MAX / VK integrations. Enable each webhook only after its channel is configured.
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_BOT_NAME=metrotherapy
MAX_BOT_LINK_BASE=https://max.ru/bot/{payload}
MAX_API_BASE_URL=https://platform-api.max.ru
VK_GROUP_TOKEN=
VK_CONFIRMATION_TOKEN=
VK_SECRET=
VK_GROUP_ID=238191212
VK_API_VERSION=5.199

# Optional AI configuration.
AI_ENABLED=1
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_THINKING=disabled

MORNING_TIME=08:30
EVENING_TIME=19:30
SOFT_CALLBACK_RATE_LIMIT_SEC=0.05
SOFT_MESSAGE_RATE_LIMIT_SEC=0.05
PREWARM_ENABLED=0
PREWARM_CHAT_ID=
