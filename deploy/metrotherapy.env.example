# Metrotherapy production environment example.
# Fill real secret values only on the server, never in the repository.

APP_ENV=prod
BOT_TOKEN=
ADMIN_IDS=

VALIDATOR_RELEASE_MODE=1
VALIDATOR_GUARDRAILS_STRICT=1

TOKEN_ENFORCEMENT_MODE=hard
TOKEN_ECONOMY_ENABLED=1

# Production storage contract: Postgres only.
METRO_DB_ENGINE=postgres
DATABASE_URL=postgresql://localhost:5432/metrotherapy

TIMEZONE=Europe/Amsterdam
LOG_PATH=/var/log/metrotherapy/app.log

# Optional in-process restart guard. systemd remains the canonical supervisor.
APP_SELF_HEAL_RESTART=0
APP_SELF_HEAL_MAX_RESTARTS=3
APP_SELF_HEAL_BACKOFF_SEC=2

HEALTHCHECK_ENABLED=1
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=8082
# Public /health, /healthz and /readyz responses are intentionally minimal.
# Set a strong secret to receive full diagnostics through either the
# X-Metrotherapy-Diagnostics-Token header or an Authorization: Bearer header.
HEALTHCHECK_DIAGNOSTICS_TOKEN=

# Shared HTTP ingress bind. Individual surfaces are enabled independently below.
MESSENGER_WEBHOOK_ENABLED=0
MESSENGER_WEBHOOK_HOST=127.0.0.1
MESSENGER_WEBHOOK_PORT=8081
MESSENGER_PUBLIC_BASE_URL=https://metrotherapy-bot.metrotherapy.ru
PAYMENT_PUBLIC_BASE_URL=https://metrotherapy-bot.metrotherapy.ru
PAYMENT_HTTP_ENABLED=1
MAX_WEBHOOK_ENABLED=0
VK_WEBHOOK_ENABLED=0

# Durable VK/MAX reply delivery. Replies are persisted before the webhook is
# acknowledged, leased by a Postgres worker and retried after provider failures.
MESSENGER_OUTBOX_MAX_ATTEMPTS=8
MESSENGER_OUTBOX_LOCK_TTL_SEC=900
MESSENGER_OUTBOX_IDLE_SLEEP_SEC=0.5
# /readyz fails when the running delivery worker falls behind these limits.
MESSENGER_OUTBOX_READY_MAX_PENDING_AGE_SEC=300
MESSENGER_OUTBOX_READY_MAX_RETRY_AGE_SEC=1800
MESSENGER_OUTBOX_READY_MAX_BACKLOG=1000

# Shared aiohttp request cap and tighter YooKassa webhook admission controls.
# TRUST_PROXY_HEADERS may be 1 only when an owned reverse proxy overwrites the
# forwarding headers; otherwise rate limiting uses the direct peer address.
HTTP_INGRESS_MAX_BODY_BYTES=1048576
PAYMENT_WEBHOOK_MAX_BODY_BYTES=65536
PAYMENT_WEBHOOK_RATE_LIMIT=30
PAYMENT_WEBHOOK_RATE_WINDOW_SEC=60
PAYMENT_WEBHOOK_MAX_INFLIGHT=4
PAYMENT_WEBHOOK_QUEUE_TIMEOUT_MS=100
TRUST_PROXY_HEADERS=0

# Telegram production contract: polling only.
TELEGRAM_TRANSPORT=polling
TELEGRAM_WEBHOOK_ENABLED=0
TELEGRAM_LEGACY_TOKEN_WEBHOOK_ENABLED=0
ALLOW_INSECURE_TELEGRAM_WEBHOOK=0
TELEGRAM_BOT_USERNAME=metrotherapybot

# Telegram digital packages are Stars-only. The UI first asks whether the buyer
# already has Stars or needs to top up, and only then creates the package invoice.
# TELEGRAM_YOOKASSA_ENABLED must stay 0; VK, MAX and web keep their independent
# YooKassa checkout through the shared payment runtime.
TELEGRAM_STARS_ENABLED=1
TELEGRAM_YOOKASSA_ENABLED=0
TELEGRAM_STARS_PRICING_MODE=explicit
TELEGRAM_STARS_PRICE_PRACTICE_START_7=1500
TELEGRAM_STARS_PRICE_PRACTICE_60=2500
TELEGRAM_STARS_PRICE_PRACTICE_ANTISTRESS_60=5000
TELEGRAM_STARS_PRICE_PRACTICE_PERSONAL_MONTH=15000
# Legacy emergency mode only. Do not use for the normal buyer-facing ladder:
TELEGRAM_STARS_BUYER_RUB_PER_XTR=1.54905
PAYMENT_TERMS_URL=https://metrotherapy-bot.metrotherapy.ru/terms
PAYMENT_SUPPORT_CONTACT=@metrotherapysupportbot
PAYMENT_MERCHANT_NAME=Метротерапия

# Optional Telegram webhook fields are dev/compatibility only and must stay empty in prod.
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8081
TELEGRAM_WEBHOOK_PREFIX=/telegram-webhook
TELEGRAM_WEBHOOK_PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0

# YooKassa production checkout and reconciliation for VK, MAX and web.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PAYMENT_CHECKOUT_SIGNING_KEY=
# These protections are mandatory in production. The runtime and readiness
# reject disabled values rather than accepting an emergency bypass.
YOOKASSA_PROVIDER_VERIFICATION_REQUIRED=1
PAYMENT_CHECKOUT_INTENT_REQUIRED=1
